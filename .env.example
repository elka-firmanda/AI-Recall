# AI Recall Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: OpenAI API Key for embeddings
# Get from: https://platform.openai.com/api-keys
# Or use OpenRouter: https://openrouter.ai/keys
# =============================================================================
OPENAI_API_KEY=sk-your-key-here

# =============================================================================
# Optional: Embedding Provider Settings
# =============================================================================
# Provider: "openai" (default) or "openrouter"
EMBEDDING_PROVIDER=openai

# Model name (provider-specific)
# OpenAI options: text-embedding-3-small (1536), text-embedding-3-large (3072)
# OpenRouter: openai/text-embedding-3-small, etc.
EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Optional: Server Settings
# =============================================================================
# AI_RECALL_SERVER_HOST=0.0.0.0
# AI_RECALL_SERVER_PORT=8080
# AI_RECALL_SERVER_AUTH_TOKEN=arec_auto_generated

# =============================================================================
# Optional: Alternative - OpenRouter Configuration
# Uncomment these to use OpenRouter instead of OpenAI directly
# =============================================================================
# OPENAI_API_KEY=sk-or-v1-your-openrouter-key
# EMBEDDING_PROVIDER=openrouter
# EMBEDDING_MODEL=openai/text-embedding-3-small
